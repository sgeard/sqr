# errors.test — statements sqr's subset rejects. `statement error` passes when
# sqlsh reports an error; it documents the subset's boundaries as much as it
# tests them.

statement ok
CREATE TABLE t3(a INTEGER, b INTEGER)

statement ok
INSERT INTO t3 VALUES(1, 2)

# Unknown table.
statement error
SELECT a FROM no_such_table

# JOIN is out of scope for the subset.
statement error
SELECT a FROM t3 JOIN t3

# Aggregates are not supported.
statement error
SELECT COUNT(*) FROM t3

# Subqueries are not supported.
statement error
SELECT a FROM t3 WHERE a IN (SELECT a FROM t3)

# LIKE is not supported.
statement error
SELECT a FROM t3 WHERE b LIKE '2'

# A well-formed statement still succeeds (guards against the harness reporting
# everything as an error).
statement ok
SELECT a FROM t3 WHERE a = 1
